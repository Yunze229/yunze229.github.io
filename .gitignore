public/
resources/
.hugo_build.lock
.DS_Store
**/.DS_Store
node_modules/
static/capsule-worker/node_modules/
.tokenize/
**/.tokenize/
**/.wrangler/

# Content lives in Yunze229/yunze-private; deploy.yml pulls it at build time.
# .md files under these paths must NEVER be committed to this public repo.
# _index.md is allowed because Hugo needs it to render the section.
content/posts/*.md
!content/posts/_index.md
content/private/*.md
!content/private/_index.md
content/learning/*.md
!content/learning/_index.md
content/capsule/*.md
!content/capsule/_index.md
content/projects/*.md
!content/projects/_index.md
content/manual/*.md
!content/manual/_index.md
# AI translations also live in the private repo.
data/translations/*.yaml
# Data yaml managed via CMS, in the private repo.
data/nav.yaml
data/books.yaml
data/gears.yaml
data/travel.yaml
data/skills.yaml
# Uploaded images live in the private repo (slug subdirs).
static/images/uploads/
# Build-time staging directory for the private repo checkout.
.private-src/

# grill multi-agent review reports — written next to the audited code,
# would otherwise get accidentally pushed to GitHub Pages.
grill-report-*.md

# >>> cc-suite >>>
# AI assistant local state
.claude/settings.local.json
.claude/CLAUDE.local.md
.claude/*.local.*
CLAUDE.local.md

# Codex CLI — local files, keep checked-in subdirs
.codex/*
!.codex/skills/
!.codex/prompts/
!.codex/hooks.json
!.codex/hooks.cc-suite.json
!.codex/config.toml

# Gemini CLI — local files, keep checked-in subdirs
.gemini/*
!.gemini/skills/
!.gemini/commands/

# Skill symlinks are machine-local absolute paths (regenerated by the cc-suite
# plugin on each machine) — never commit them to this public repo.
.claude/skills/
.agents/
# <<< cc-suite <<<
content/timeline/*.md
!content/timeline/_index.md
